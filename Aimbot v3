		TargetPart = "Head"
		partBtn.Text = "TARGET: HEAD"
	else
		TargetPart = "HumanoidRootPart"
		partBtn.Text = "TARGET: BODY"
	end
 
end)
 
typeBtn.MouseButton1Click:Connect(function()
 
	if TargetType == "ALL" then
		TargetType = "PLAYER"
		typeBtn.Text = "TYPE: PLAYER"
 
	elseif TargetType == "PLAYER" then
		TargetType = "NPC"
		typeBtn.Text = "TYPE: NPC"
 
	else
		TargetType = "ALL"
		typeBtn.Text = "TYPE: ALL"
	end
 
end)
 
-- Main Loop
RunService.RenderStepped:Connect(function()
 
	local runtime = math.floor(tick() - StartTime)
 
	runtimeLabel.Text =
		"Runtime: "..runtime.."s"
 
	circle.Position = Vector2.new(
		Camera.ViewportSize.X/2,
		Camera.ViewportSize.Y/2
	)
 
	circle.Radius = FOV
	circle.Visible = true
 
	if not Enabled then return end
 
	local target = getTarget()
 
	if target then
 
		local part = target:FindFirstChild(TargetPart)
 
		if part then
 
			local camPos = Camera.CFrame.Position
 
			-- Hard Lock
			Camera.CFrame =
				CFrame.new(camPos, part.Position)
		end
	end
end)
