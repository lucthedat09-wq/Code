-- =====================
-- TAB SWITCHING
-- =====================
local allTabs = {
    { btn = quickTabBtn,    frame = quickTab,    name = "quick" },
    { btn = carsTabBtn,     frame = carsTab,     name = "cars" },
    { btn = autoBuyTabBtn,  frame = autoBuyTab,  name = "autobuy" },
    { btn = farmTabBtn,     frame = farmTab,     name = "farm" },
    { btn = settingsTabBtn, frame = settingsTab, name = "settings" },
}

local function switchTab(tabName)
    currentTab = tabName
    for _, t in ipairs(allTabs) do
        t.frame.Visible = t.name == tabName
        t.btn.BackgroundColor3 = t.name == tabName and Color3.fromRGB(70, 70, 200) or Color3.fromRGB(38, 38, 52)
        t.btn.TextColor3 = t.name == tabName and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(160, 160, 180)
    end
end

switchTab("quick")
quickTabBtn.MouseButton1Click:Connect(function() switchTab("quick") end)
carsTabBtn.MouseButton1Click:Connect(function() switchTab("cars") refreshCarList() end)
autoBuyTabBtn.MouseButton1Click:Connect(function() switchTab("autobuy") end)
farmTabBtn.MouseButton1Click:Connect(function() switchTab("farm") end)
settingsTabBtn.MouseButton1Click:Connect(function() switchTab("settings") end)

