-- =====================
-- KEYBIND HANDLER
-- =====================
local inputConn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not running then return end
    if bindSetting and input.UserInputType == Enum.UserInputType.Keyboard then
        currentBind = input.KeyCode
        bindButton.Text = "Bind: " .. currentBind.Name
        bindButton.BackgroundColor3 = Color3.fromRGB(26, 26, 36)
        bindSetting = false
        return
    end
    if gameProcessed or bindSetting then return end
    if input.KeyCode == currentBind then
        setToggle(not isToggled)
    end
end)

table.insert(connections, inputConn)
