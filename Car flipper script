local function autoBuyLoop()
    while flipRunning do
        if not isProcessing and not isCollecting and not isDelivering then
            local activeMerchants = workspace:FindFirstChild("ActiveMerchants")
         if activeMerchants then
                for _, merchant in ipairs(activeMerchants:GetChildren()) do
                    if not flipRunning then break end
                    if isProcessing then break end
                    if merchant:IsA("Folder") then
                        for _, obj in ipairs(merchant:GetChildren()) do
                            if not flipRunning then break end
                            if isProcessing then break end
                            if obj:IsA("Model") and isValidCar(obj.Name) then
                                local rarity = getCarRarity(obj.Name)
                                if flipSelectedRarities[rarity] then
                                    local prompt = obj:FindFirstChild("MerchantPrompt", true)
                                    if prompt then
                                        local zone = prompt:GetAttribute("MerchantZone")
                                        local id   = prompt:GetAttribute("MerchantId")
                                        if zone and id then
                                            isProcessing = true
                                            autoBuyStatusLabel.Text = "Status: Buying " .. obj.Name
                                            local character = localPlayer.Character
                                            if character and character:FindFirstChild("HumanoidRootPart") then
                                                local part = (obj:IsA("Model") and obj.PrimaryPart)
                                                    or obj:FindFirstChildWhichIsA("BasePart", true)
                                                if part then
                                                    safeTeleport(character.HumanoidRootPart, part.Position)
                                                end
                                            end
                                            BuyCar:FireServer(zone, id)
                                            task.wait(1.5)
                                            isProcessing = false
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
        autoBuyStatusLabel.Text = "Status: Scanning..."
        task.wait(2)
    end
    autoBuyStatusLabel.Text = "Status: Idle"
end

-- =====================
-- AREA ROTATION LOOP (AUTO-BUY)
-- =====================
local function areaRotationLoop()
    currentAreaIndex = 1
    while areaRotateRunning do
        local area = AREAS[currentAreaIndex]
        currentAreaLabel.Text = "Area: " .. area.name
        autoBuyStatusLabel.Text = "Status: Teleporting to " .. area.name
        teleportToArea(area)
        task.wait(1.5)

        autoBuyStatusLabel.Text = "Status: Scanning " .. area.name
        local activeMerchants = workspace:FindFirstChild("ActiveMerchants")
        if activeMerchants then
            for _, merchant in ipairs(activeMerchants:GetChildren()) do
                if not areaRotateRunning then break end
                if merchant:IsA("Folder") then
                    for _, obj in ipairs(merchant:GetChildren()) do
                        if not areaRotateRunning then break end
                        if isProcessing or isCollecting or isDelivering then
                            while (isProcessing or isCollecting or isDelivering) and areaRotateRunning do
                                task.wait(0.3)
                            end
                        end
                        if not areaRotateRunning then break end
                        if obj:IsA("Model") and isValidCar(obj.Name) then
                            local rarity = getCarRarity(obj.Name)
                            if flipSelectedRarities[rarity] then
                                local prompt = obj:FindFirstChild("MerchantPrompt", true)
                                if prompt then
                                    local zone = prompt:GetAttribute("MerchantZone")
                                    local id   = prompt:GetAttribute("MerchantId")
                                    if zone and id then
                                        isProcessing = true
                                        autoBuyStatusLabel.Text = "Status: Buying " .. obj.Name
                                        local character = localPlayer.Character
                                        if character and character:FindFirstChild("HumanoidRootPart") then
                                            local part = (obj:IsA("Model") and obj.PrimaryPart)
                                                or obj:FindFirstChildWhichIsA("BasePart", true)
                                            if part then
                                                safeTeleport(character.HumanoidRootPart, part.Position)
                                            end
                                        end
                                        BuyCar:FireServer(zone, id)
                                        task.wait(1.5)
                                        isProcessing = false
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end

        currentAreaIndex = (currentAreaIndex % #AREAS) + 1
        task.wait(2)
    end
    autoBuyStatusLabel.Text = "Status: Idle"
    currentAreaLabel.Text = "Area: —"
end

-- =====================
-- FARM LOOP
-- =====================
local function farmLoop()
    while farmRunning do
        local activeMerchants = workspace:FindFirstChild("ActiveMerchants")
        if not activeMerchants then
            farmStatusLabel.Text = "Status: Waiting for merchants..."
            task.wait(2)
            continue
        end
        local foundCar = false
        for _, merchant in ipairs(activeMerchants:GetChildren()) do
            if not farmRunning then break end
            if merchant:IsA("Folder") then
                for _, obj in ipairs(merchant:GetChildren()) do
                    if not farmRunning then break end
                    if obj:IsA("Model") and isValidCar(obj.Name) then
                        if processFarmCar(obj) then foundCar = true end
                        while (isProcessing or isCollecting or isDelivering) and farmRunning do
                            task.wait(0.3)
                        end
                    end
                end
            end
        end
        if not foundCar then
            -- Build a label listing all selected rarities
            local selectedNames = {}
            for i = 0, 4 do
                if farmSelectedRarities[i] then
                    table.insert(selectedNames, RARITY_INFO[i].name)
                end
            end
            local rarityStr = #selectedNames > 0 and table.concat(selectedNames, "/") or "None"
            farmStatusLabel.Text = "Status: Scanning for " .. rarityStr .. " cars..."
        end
        task.wait(2)
    end
    farmStatusLabel.Text = "Status: Idle"
end

-- =====================
-- FARM AREA ROTATION LOOP
-- =====================
local function farmAreaRotationLoop()
    farmAreaIndex = 1
    while farmAreaRotateRunning do
        local area = AREAS[farmAreaIndex]
        farmCurrentAreaLabel.Text = "Area: " .. area.name
        farmStatusLabel.Text = "Status: Teleporting to " .. area.name
        teleportToArea(area)
        task.wait(1.5)

        farmStatusLabel.Text = "Status: Scanning " .. area.name
        local activeMerchants = workspace:FindFirstChild("ActiveMerchants")
        if activeMerchants then
            for _, merchant in ipairs(activeMerchants:GetChildren()) do
                if not farmAreaRotateRunning then break end
                if merchant:IsA("Folder") then
                    for _, obj in ipairs(merchant:GetChildren()) do
                        if not farmAreaRotateRunning then break end
                        if obj:IsA("Model") and isValidCar(obj.Name) then
                            processFarmCar(obj)
                            while (isProcessing or isCollecting or isDelivering) and farmAreaRotateRunning do
                                task.wait(0.3)
                            end
                        end
                    end
                end
            end
        end

        farmAreaIndex = (farmAreaIndex % #AREAS) + 1
        task.wait(2)
    end
    farmStatusLabel.Text = "Status: Idle"
    farmCurrentAreaLabel.Text = "Area: —"
end

