local function repairCar(carIndex, statusLabelRef)
    statusLabelRef.Text = "Status: Repairing car [" .. carIndex .. "]..."
    local maxAttempts = 15
    local attempt = 0
    while farmRunning and attempt < maxAttempts do
        attempt = attempt + 1
        FixCar:FireServer(carIndex)
        task.wait(0.6)
    end
end

local function sellCar(carIndex, statusLabelRef)
    statusLabelRef.Text = "Status: Selling car [" .. carIndex .. "]..."
    SellCar:FireServer(carIndex)
    task.wait(1)
end

-- =====================
-- PROCESS ONE FARM CAR
-- =====================
local function processFarmCar(obj)
    local rarity = getCarRarity(obj.Name)
    if not farmSelectedRarities[rarity] then return false end
    if isProcessing or isCollecting or isDelivering then return false end

    isProcessing = true
    farmStatusLabel.Text = "Status: Processing " .. obj.Name .. "..."

    local success = doBuySequence(obj, farmStatusLabel)
    if not success then
        isProcessing = false
        return false
    end

    farmStatusLabel.Text = "Status: Finding car in garage..."
    local carIndex = nil
    for attempt = 1, 10 do
        carIndex = findNewestCarIndex()
        if carIndex then break end
        task.wait(0.5)
    end

    if not carIndex then
        farmStatusLabel.Text = "Status: Garage index not found, defaulting to 16"
        carIndex = "16"
    else
        farmStatusLabel.Text = "Status: Got index [" .. carIndex .. "]"
    end

    -- Close garage before repairing
    farmStatusLabel.Text = "Status: Closing garage..."
    forceCloseGarage()
    task.wait(0.5)

    repairCar(carIndex, farmStatusLabel)
    task.wait(0.5)

    sellCar(carIndex, farmStatusLabel)
    task.wait(1)

    isProcessing = false
    farmStatusLabel.Text = "Status: Cycle complete! ✓"
    return true
end

-- =====================
-- AUTO-COLLECT LOOP
-- =====================
local function collectLoop()
    collectNextTime = os.clock()
    while collectRunning do
        local now = os.clock()
        local remaining = collectNextTime - now
        if remaining <= 0 then
            while isProcessing and collectRunning do
                farmStatusLabel.Text = "Status: Waiting to collect (car processing)..."
                task.wait(0.5)
            end
            if not collectRunning then break end
            collectResources(farmStatusLabel)
            collectCountdownLabel.Text = "Next collect: 5:00"
        else
            local mins = math.floor(remaining / 60)
            local secs = math.floor(remaining % 60)
            collectCountdownLabel.Text = string.format("Next collect: %d:%02d", mins, secs)
        end
        task.wait(1)
    end
    collectCountdownLabel.Text = "Next collect: —"
end

