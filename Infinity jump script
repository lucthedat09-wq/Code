local function notify(title, text, duration)
    duration = duration or 3
    pcall(function() 
        StarterGui:SetCore("ChatMakeSystemMessage", { 
            Text = "[" .. title .. "] " .. text, 
            Color = Color3.new(1, 1, 1), 
            Font = Enum.Font.SourceSansBold 
        }) 
    end)
end

local function createGuiTemplate(params)
